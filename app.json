{
  "expo": {
    "name": "Hit-Me-App",
    "slug": "Hit-Me-App",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "hitmeapp",
    "extra": {
      "googleExpoClientId": "480875423405-3smkqrm58p54j6erdfl2hlr1k827fbo5.apps.googleusercontent.com",
      "googleAndroidClientId": "480875423405-3smkqrm58p54j6erdfl2hlr1k827fbo5.apps.googleusercontent.com",
      "googleWebClientId": "480875423405-3smkqrm58p54j6erdfl2hlr1k827fbo5.apps.googleusercontent.com"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hitmeapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.hitmeapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/splash-icon.png"
        }
      ],
      "expo-web-browser"
    ]
  }
}
